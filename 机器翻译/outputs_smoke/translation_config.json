{
  "data_file": "../spa.txt",
  "output_dir": "outputs_smoke",
  "seed": 42,
  "max_samples": 7000,
  "max_seq_len": 20,
  "max_vocab_src": 18000,
  "max_vocab_tgt": 18000,
  "min_token_freq": 1,
  "batch_size": 48,
  "embedding_dim": 128,
  "hidden_dim": 160,
  "num_heads": 4,
  "num_layers": 2,
  "ff_dim": 256,
  "dropout": 0.1,
  "epochs_seq2seq": 2,
  "epochs_transformer": 2,
  "lr_seq2seq": 0.001,
  "lr_transformer": 0.0008,
  "early_stopping_patience_seq2seq": 2,
  "early_stopping_patience_transformer": 2,
  "early_stopping_min_delta_bleu": 0.0001,
  "teacher_forcing_ratio": 0.5,
  "train_ratio": 0.8,
  "val_ratio": 0.1,
  "test_ratio": 0.1,
  "bleu_eval_every": 1,
  "bleu_val_sample_size": 240,
  "beam_size": 4,
  "length_penalty": 0.7,
  "quick": true,
  "device": "cuda"
