{
  "data_file": "../reuters.npz",
  "output_dir": "outputs",
  "seed": 42,
  "max_vocab_size": 20000,
  "max_seq_len": 240,
  "embedding_dim": 128,
  "hidden_dim": 160,
  "num_heads": 4,
  "num_transformer_layers": 2,
  "ff_dim": 256,
  "dropout": 0.3,
  "batch_size": 64,
  "epochs": 15,
  "lr": 0.001,
  "weight_decay": 1e-05,
  "early_stopping_patience": 4,
  "early_stopping_min_delta": 0.0001,
  "test_ratio": 0.2,
  "val_ratio": 0.1,
  "max_samples": 11228,
  "device": "mps",
  "quick": false,
  "include_hybrid": false,
  "loss": "focal",
  "focal_gamma": 5.0,
  "output_suffix": "_focal_g5.0"
}